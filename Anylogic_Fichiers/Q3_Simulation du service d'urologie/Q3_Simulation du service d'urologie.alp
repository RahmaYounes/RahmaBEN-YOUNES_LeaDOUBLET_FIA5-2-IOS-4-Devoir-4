			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1779111674203</Id>
					<Name><![CDATA[tauxArrivee]]></Name>
					<X>480</X><Y>520</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>false</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (time() < 360) {
    return lambdaAM;
} else if (time() < 720) {
    return lambdaPM;
} else {
    return 0;
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1779117448746</Id>
					<Name><![CDATA[saturation]]></Name>
					<X>480</X><Y>550</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>false</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return time() >= 720 && nbSortis < nbEntres;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1779117499306</Id>
					<Name><![CDATA[tempsMoyenSysteme]]></Name>
					<X>480</X><Y>580</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>false</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return nbSortis > 0 ? DelaiTotal / nbSortis : 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[String]]></ReturnType>
					<Id>1779117566213</Id>
					<Name><![CDATA[resultatSimulation]]></Name>
					<X>480</X><Y>610</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>false</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return "Entrés = " + nbEntres
    + "\nSortis = " + nbSortis
    + "\nDernier départ = " + (((int)Math.round(8 * 60 + Depart) / 60) % 24)
+ "h"
+ String.format("%02d", ((int)Math.round(8 * 60 + Depart) % 60))
+ (((int)Math.round(8 * 60 + Depart) / 60) >= 24 ? " (J+1)" : "")
+ " (" + String.format("%.1f", Depart) + " min)"
    + "\nTemps MOY système = " + (nbSortis > 0 ? String.format("%.2f", DelaiTotal / nbSortis) : "0") 
    + "\nSaturation = " + saturation();]]></Body>
				</Function>
			</Functions>
