					<Action><![CDATA[poolAccueil.set_capacity(nbAccueilAprem);
poolConsultation.set_capacity(nbConsultAprem);
poolExamen.set_capacity(nbExamenAprem);
poolSortie.set_capacity(nbSortieAprem);]]></Action>
