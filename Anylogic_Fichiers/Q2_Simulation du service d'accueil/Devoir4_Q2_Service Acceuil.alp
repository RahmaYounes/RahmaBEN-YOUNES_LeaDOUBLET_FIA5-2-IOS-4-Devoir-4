					<Name><![CDATA[Affichage]]></Name>
					<X>720</X><Y>340</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="occuresOnce">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_MINUTE]]></Unit>
						</Rate>
						<Id>1779342689378</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1779350400000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[600]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[traceln("===== RESULTATS SIMULATION =====");

traceln("");

traceln("Entres = " + nbEntres);

traceln("Sortis = " + nbSortiesTotal);

traceln("");

traceln("Patients matin = " + nbMatin);

traceln("Patients apres-midi = " + nbAprem);

traceln("");

traceln("Temps moyen systeme = "
+ Math.round((DelaiSysteme / nbSortiesTotal) * 100.0) / 100.0
+ " min");

traceln("");

traceln("Attente moyenne prio = "
+ Math.round((DelaiPrio / nbSortiesPrio) * 100.0) / 100.0
+ " min");

traceln("Attente moyenne standard = "
+ Math.round((DelaiAutre / nbSortiesAutre) * 100.0) / 100.0
+ " min");

traceln("");

traceln("Occupation prio = "
+ Math.round((100 * tempsServicePrio / time()) * 100.0) / 100.0
+ " %");

traceln("Occupation standard = "
+ Math.round((100 * tempsServiceAutre / time()) * 100.0) / 100.0
+ " %");

traceln("");

traceln("Service moyen prio = "
+ Math.round((ServicePrio / nbSortiesPrio) * 100.0) / 100.0
+ " min");

traceln("Service moyen standard = "
+ Math.round((ServiceAutre / nbSortiesAutre) * 100.0) / 100.0
+ " min");

traceln("");

traceln("Dernier depart = "
+ Math.round(Sortie * 100.0) / 100.0
+ " min");]]></Action>
				</Event>
			</Events>
